{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "A health profile for the user or a family member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "relationship": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "bloodType": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "relationship"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "An extracted medical record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "date": { "type": "string" },
        "doctor": { "type": "string" },
        "hospital": { "type": "string" },
        "summary": { "type": "string" },
        "extractedData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "date"]
    },
    "Medication": {
      "title": "Medication",
      "description": "A tracked medication",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "schedule": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dosage", "frequency"]
    },
    "ShareLink": {
      "title": "Share Link",
      "description": "A secure sharing link for a doctor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "recordIds": { "type": "array", "items": { "type": "string" } },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "profileId"]
    }
  },
  "firestore": {
    "users/{userId}/profiles/{profileId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Profiles belonging to a user"
    },
    "users/{userId}/profiles/{profileId}/records/{recordId}": {
      "schema": { "$ref": "#/entities/MedicalRecord" },
      "description": "Medical records for a specific profile"
    },
    "users/{userId}/profiles/{profileId}/medications/{medId}": {
      "schema": { "$ref": "#/entities/Medication" },
      "description": "Medications for a specific profile"
    },
    "shares/{shareId}": {
      "schema": { "$ref": "#/entities/ShareLink" },
      "description": "Publicly accessible share links (read-only, checked by expiry)"
    }
  }
}
